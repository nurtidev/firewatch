# ─── Database (PostGIS) ───────────────────────────────────────────────
POSTGRES_USER=firewatch
POSTGRES_PASSWORD=firewatch
POSTGRES_DB=firewatch
# Used by api/ml. In Railway set this to a reference to the PostGIS service.
DATABASE_URL=postgresql+psycopg://firewatch:firewatch@db:5432/firewatch

# ─── Claude (Anthropic) ───────────────────────────────────────────────
# Modules 03 (card extraction) and 06 (chat analyst)
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Internal service URLs ────────────────────────────────────────────
ML_URL=http://ml:8000
OSRM_URL=http://routing:5000
# Public Overpass mirror (OSM building import). Replace with self-hosted later.
OVERPASS_URL=https://overpass-api.de/api/interpreter

# ─── Auth ─────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ─── Frontend ─────────────────────────────────────────────────────────
# Base URL the browser uses to reach the API.
NEXT_PUBLIC_API_URL=http://localhost:8001
